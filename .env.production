# 生产环境配置
# 请根据您的服务器实际情况修改

# MongoDB连接
# 如果MongoDB在Docker容器中（1Panel默认）
MONGODB_URI=mongodb://localhost:27017/forge-duel

# 如果MongoDB设置了认证
# MONGODB_URI=mongodb://用户名:密码@localhost:27017/forge-duel?authSource=admin

# Session密钥 - 请务必修改为复杂的随机字符串！
# 生成方法：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=请改成超级复杂的随机字符串-至少32位

# 服务器端口
PORT=8080

# 环境
NODE_ENV=production
